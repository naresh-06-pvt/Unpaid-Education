# ansible/inventory

[dev]
dev-server ansible_host=192.168.56.10 ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/id_rsa

[staging]
staging-server ansible_host=staging.example.com ansible_user=ec2-user ansible_ssh_private_key_file=~/.ssh/staging_key.pem

[prod]
prod-server ansible_host=prod.example.com ansible_user=ec2-user ansible_ssh_private_key_file=~/.ssh/prod_key.pem
